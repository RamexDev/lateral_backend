# Core API settings
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
LOG_LEVEL=info
CORS_ORIGIN=*

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=zwuwur
DB_PASSWORD=changeme
DB_NAME=zwuwur
DB_CONNECTION_LIMIT=10

# Redis
REDIS_URL=redis://127.0.0.1:6379

# User JWT
USER_JWT_SECRET=dev-user-secret-change-me
USER_JWT_EXPIRES_IN=30d

# Admin JWT
ADMIN_ACCESS_TOKEN_SECRET=dev-admin-secret-change-me
ADMIN_ACCESS_TOKEN_EXPIRES_IN=15m
ADMIN_REFRESH_TOKEN_EXPIRES_IN=7d

# Telegram
TELEGRAM_BOT_TOKEN=dev-telegram-token
TELEGRAM_WEBHOOK_SECRET=dev-telegram-webhook-secret
MINI_APP_URL=https://t.me/zwuwur_bot/app

# Payments
PAYMENT_PROVIDER=chapa
CHAPA_SECRET_KEY=dev-chapa-secret
CHAPA_WEBHOOK_SECRET=dev-chapa-webhook-secret
CHAPA_BASE_URL=https://api.chapa.co/v1
TELEBIRR_APP_ID=dev-telebirr-app-id
TELEBIRR_APP_KEY=dev-telebirr-app-key
TELEBIRR_WEBHOOK_SECRET=dev-telebirr-webhook-secret
TELEBIRR_BASE_URL=https://app.telebirr.com
CURRENCY=ETB
REVEAL_PRICE_ETB=500

# Notifications
DIGEST_CRON=0 6 * * *
DIGEST_TIMEZONE=Africa/Addis_Ababa

# Super admin bootstrap
SUPER_ADMIN_EMAIL=admin@zwuwur.app
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_FULL_NAME=Root Admin

# Uploads
AVATAR_STORAGE_DIR=./storage/avatars
MAX_UPLOAD_MB=5
PUBLIC_ASSET_BASE_URL=http://localhost:3000

# Seed flags
SEED_USE_ENGLISH_AS_AMHARIC_PLACEHOLDER=true
SEED_FINFINNE_SURROUNDING_ACTIVE=false
REQUIRE_AMHARIC_REVIEW=false

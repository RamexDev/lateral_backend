/**
 * sequelize-cli configuration — points the CLI at our Sequelize layout.
 *
 * - config:    DB connection params per NODE_ENV (read from env at runtime)
 * - models:    single index file that wires up the Sequelize instance + associations
 * - migrations: sequelize-cli migration files (one per table, mirrors §3.2 order)
 * - seeders:   Sequelize seeders (banks/geography, grades, super admin)
 */
const path = require('path');

module.exports = {
  config: path.resolve('src/db', 'config.js'),
  'models-path': path.resolve('src/db', 'models/index.js'),
  'migrations-path': path.resolve('src/db', 'migrations'),
  'seeders-path': path.resolve('src/db', 'seeders'),
};

# ─── Application ────────────────────────────────────────────────────────────
# Node environment: 'development' (default), 'test' (SQLite + inline queue fallback),
# or 'production' (MySQL + Redis-backed BullMQ workers required).
NODE_ENV=development
# Port the API server listens on. Worker + scheduler processes don't bind a port.
PORT=3000

# ─── Database (MySQL — dev/prod only; tests use in-memory SQLite) ──────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lateral_transfer
DB_USER=root
DB_PASSWORD=
# Connection pool size bounds (mysql2).
DB_POOL_MIN=2
DB_POOL_MAX=20
# Set to 'true' to enable MySQL TLS with rejectUnauthorized.
DB_SSL=false
# Set to 'true' to log every SQL statement Sequelize issues (verbose — dev only).
SEQUELIZE_LOG=false

# ─── Redis (cache + BullMQ queues + rate limiter) ───────────────────────────
# Format: redis://[:password@]host:port/db
# If unset: API process falls back to in-memory Map (dev/test only). Worker +
# scheduler processes refuse to start without it.
REDIS_URL=

# ─── JWT ────────────────────────────────────────────────────────────────────
# Secret used to sign all JWTs (user + staff access + staff refresh token hash
# input). CHANGE THIS IN PRODUCTION — the default is a known dev value.
JWT_SECRET=dev-jwt-secret-change-me
# User JWT expiry (default 7d — long-lived because the bot/Mini App is the only
# place these tokens are used, and there's no user password flow).
JWT_EXPIRES_IN=7d
# Staff access JWT hard expiry (SEC-009 backstop). 30 minutes by default —
# combined with the frontend's 10-minute idle logout (ADMIN_IDLE_TIMEOUT_MINUTES)
# this bounds a stolen/leaked access token's lifetime.
ADMIN_JWT_EXPIRES_IN=30m
# Staff refresh token TTL (answers.md §D). 7 days by default — staff can silently
# refresh their access token within this window without re-entering credentials.
ADMIN_REFRESH_TOKEN_EXPIRES_IN=7d
# Legacy config — same as ADMIN_JWT_EXPIRES_IN. Kept for backward compat.
ADMIN_SESSION_TTL_MINUTES=30
# Frontend-enforced idle timeout in minutes (answers.md §D). The backend doesn't
# enforce this — it's documentation for the Admin PWA's idle-detection timer.
ADMIN_IDLE_TIMEOUT_MINUTES=10

# ─── CORS (per-router — SEC-011) ────────────────────────────────────────────
# Allowed origin(s) for the /api/v1/* router (bot webhook + Mini App traffic).
# Use a comma-separated list or '*' for wildcard.
MINIAPP_ORIGIN=*
# Allowed origin(s) for the /admin/api/v1/* router (Admin PWA traffic).
ADMIN_PWA_ORIGIN=*

# ─── Telegram (bot — for initData verification + bot gateway trust) ─────────
# Bot token from @BotFather. Required for SEC-003 initData verification.
TELEGRAM_BOT_TOKEN=
# Shared secret for authenticating the Telegram bot webhook (legacy — kept for
# the bot-webhook trust path; not used by the Chapa webhook).
TELEGRAM_WEBHOOK_SECRET=

# ─── Chapa payment provider (answers.md §1) ────────────────────────────────
# Chapa API base URL. Use 'https://api.chapa.co/v1' for production.
CHAPA_API_BASE=https://api.chapa.co/v1
# Chapa secret key (Bearer token for /transaction/initialize). From your Chapa
# dashboard. If unset, createInvoice() returns a deterministic fake URL (dev/test).
CHAPA_SECRET_KEY=
# Chapa public key (used client-side by the Mini App; not currently read by the
# backend but documented here for parity with the Chapa integration).
CHAPA_PUBLIC_KEY=
# Shared secret for HMAC-SHA256 verification of the Chapa-Signature header on
# /api/v1/webhooks/chapa. If unset, signature verification is skipped (test default).
CHAPA_WEBHOOK_SECRET=

# ─── Payments ──────────────────────────────────────────────────────────────
# Per-reveal price in ETB. Integer.
PAYMENT_AMOUNT_ETB=500
# ISO 4217 currency code for payments.
PAYMENT_CURRENCY=ETB

# ─── Business rules ────────────────────────────────────────────────────────
# Grade adjacency range for BR-003 (matches within ±N rank_order). Default 1.
DEFAULT_GRADE_ADJACENCY_RANGE=1
# Cron expression for the daily digest repeatable job (consumed by scheduler.js).
# Default: 6:00 AM every day, server timezone.
DIGEST_SCHEDULE_CRON=0 6 * * *
# Bot onboarding session TTL in hours (Redis-backed session FSM). Default 24h.
BOT_SESSION_TTL_HOURS=24

# ─── First-run super admin bootstrap ───────────────────────────────────────
# These are read by the super-admin seeder (src/db/seeders/20240101000004-super-admin.js)
# ONLY on first run — re-running the seeder won't reset these on an existing account.
SUPER_ADMIN_EMAIL=superadmin@lateral.local
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_NAME=Super Admin

# ─── Test-only flags (not for production) ──────────────────────────────────
# Set to '1' to skip Telegram initData verification in tests (only honored when
# NODE_ENV === 'test'). Used by specific edge-case tests.
TEST_SKIP_INIT_DATA=
